{
  "name": "reconcile-engine",
  "image": "mcr.microsoft.com/devcontainers/cpp:1-ubuntu-24.04",
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-vscode.cpptools",
        "ms-vscode.cmake-tools",
        "llvm-vs-code-extensions.vscode-clangd"
      ]
    }
  },
  "postCreateCommand": "sudo apt-get update && sudo apt-get install -y clang-format clang-tidy"
}
